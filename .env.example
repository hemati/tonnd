# Database (auto-configured by docker-compose, only needed for local dev without Docker)
# DATABASE_URL=postgresql+asyncpg://healthcoach:healthcoach@localhost:5432/healthcoach

# Auth secrets (change these!)
JWT_SECRET=change-me-to-a-random-secret
RESET_PASSWORD_TOKEN_SECRET=change-me-to-another-secret
VERIFICATION_TOKEN_SECRET=change-me-to-yet-another-secret

# Fitbit token encryption key
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# OAuth state signing secret
STATE_SECRET=change-me-to-a-random-secret

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Optional: Google OAuth (without these, only email/password login works)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Fitbit API (without these, no Fitbit sync)
# FITBIT_CLIENT_ID=your-fitbit-client-id
# FITBIT_CLIENT_SECRET=your-fitbit-client-secret
